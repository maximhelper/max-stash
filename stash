<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Loading...</title>
    <link id="dynamic-favicon" rel="icon" type="image/png" href="">
    
    <style>
        :root { 
            --bg: #0a0a0a; --container-bg: #161616; --text: #e0e0e0; 
            --primary: #007bff; --border: #333; --danger: #ff4757; 
            --clever: #2f5be7; --boost: #ff00ff; --clear: #00d2ff; 
        }
        
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background: var(--bg); color: var(--text); 
            display: flex; justify-content: center; align-items: center; 
            height: 100vh; margin: 0; overflow: hidden;
        }

        .app-shell {
            width: 1018px; height: 573px;
            background: var(--container-bg);
            border: 1px solid var(--border);
            border-radius: 12px;
            display: flex; flex-direction: column;
            box-shadow: 0 20px 50px rgba(0,0,0,0.8);
            position: relative; overflow: hidden;
        }
        
        .nav-tabs { 
            display: flex; flex-direction: row; gap: 12px; 
            padding: 15px 25px; border-bottom: 1px solid var(--border); 
            background: rgba(0,0,0,0.2);
        }

        .nav-tabs button { 
            background: none; border: none; color: var(--text); 
            opacity: 0.6; cursor: pointer; font-weight: bold; 
            padding: 8px 10px; font-size: 0.8em; transition: 0.2s;
        }

        .nav-tabs button.active { opacity: 1; color: var(--primary); border-bottom: 2px solid var(--primary); }
        
        .main-layout { display: flex; flex: 1; padding: 20px; gap: 20px; overflow: hidden; }
        .sidebar { width: 160px; display: flex; flex-direction: column; align-items: center; justify-content: center; border-right: 1px solid var(--border); padding-right: 20px; }
        
        .player-logo { 
            width: 70px; height: 70px; background: var(--primary); 
            border-radius: 50%; display: flex; justify-content: center; align-items: center; 
            border: 1px solid rgba(255,255,255,0.3); margin-bottom: 15px; 
            box-shadow: 0 0 15px rgba(0, 123, 255, 0.4); cursor: pointer;
        }
        .circle { width: 35px; height: 35px; background: white; border-radius: 50%; }
        .brand-title { font-size: 1.2rem; font-weight: bold; color: var(--text); }

        .content-area { flex: 1; overflow-y: auto; }
        .panel { background: rgba(255,255,255,0.03); padding: 15px; border-radius: 10px; border: 1px solid var(--border); margin-bottom: 12px; }
        .tab-content { display: none; height: 100%; }
        .tab-content.active { display: block; }
        
        .p-text { color: var(--boost); font-weight: bold; }
        .stats-font { font-family: 'Consolas', monospace; color: var(--primary); font-size: 1.1em; }
        
        input, .action-btn { width: 100%; padding: 10px; margin-bottom: 8px; border-radius: 6px; border: 1px solid var(--border); background: #111; color: white; box-sizing: border-box; }
        video { width: 100%; border-radius: 8px; background: #000; margin-top: 10px; max-height: 260px; transition: filter 0.3s; }
        .vol-slider { cursor: pointer; accent-color: var(--primary); width: 100%; height: 6px; }
    </style>
</head>
<body>

<div class="app-shell">
    <div class="nav-tabs">
        <button id="tabBtnReadme" class="active" onclick="showTab('readme', this)">README</button>
        <button id="tabBtnPlayer" onclick="showTab('player', this)">VIDEO PLAYER</button>
        <button id="tabBtnCloak" onclick="showTab('cloak', this)">CLOAKING</button>
        <button id="tabBtnStatistics" onclick="showTab('statistics', this)">STATISTICS</button>
        <button id="tabBtnGnmath" onclick="showTab('gnmath', this)">gn-math</button>
        <button onclick="systemWipe()" style="color:var(--danger); margin-left: auto;">WIPE</button>
    </div>

    <div class="main-layout">
        <div class="sidebar">
            <div class="player-logo" id="logoDev" onclick="devUnlock()"><div class="circle"></div></div>
            <div class="brand-title">max-stash</div>
        </div>

        <div class="content-area">
            <div id="tabReadme" class="tab-content active">
                <div class="panel">
                    <h3 style="margin:0; color:var(--primary);">System Status</h3>
                    <p style="font-size:0.9em;">Resolution: 1018x573<br>Delayed Cloaking: Active (1s)</p>
                </div>
            </div>

            <div id="tabPlayer" class="tab-content">
                <div class="panel">
                    <span style="font-size:0.75em;">VOL: <span id="volVal">100%</span></span>
                    <input type="range" id="volBoost" class="vol-slider" min="1" max="15" value="10">
                    <div style="display:flex; gap:8px; margin-top:10px;">
                        <button class="action-btn" id="clearBtn" onclick="toggleClearerAudio()" style="color:var(--clear); border-color:var(--clear); background:none; cursor:pointer; font-size:0.75em;">AUDIO: OFF</button>
                        <button class="action-btn" id="visionBtn" onclick="toggleVision()" style="color:var(--boost); border-color:var(--boost); background:none; cursor:pointer; font-size:0.75em;">ULTRABRIGHT: OFF</button>
                    </div>
                </div>
                <input type="file" id="f">
                <button id="mainBtn" class="action-btn" style="background:var(--primary); font-weight:bold;">INITIALIZE PLAYER</button>
                <video id="vid" controls style="display:none;"></video>
            </div>

            <div id="tabCloak" class="tab-content">
                <div class="panel">
                    <input type="text" id="cloakTitle" placeholder="Custom Tab Title">
                    <input type="text" id="cloakDomain" placeholder="Domain (e.g. google.com)">
                    <button class="action-btn" onclick="applyCustomCloak()" style="background:var(--primary); border:none;">APPLY CLOAK</button>
                    <hr style="border:0; border-top:1px solid var(--border); margin:10px 0;">
                    <button class="action-btn" onclick="applyCloak('Clever | Portal', 'clever.com')" style="background: var(--clever); border:none;">QUICK CLEVER</button>
                    <button class="action-btn" onclick="resetCloak()" style="background: #333; border:none;">RESET</button>
                </div>
            </div>

            <div id="tabStatistics" class="tab-content">
                <div class="panel">
                    <p>MEMORY USAGE:</p>
                    <div id="usedRam" class="stats-font">--- MB</div>
                </div>
            </div>

            <div id="tabGnmath" class="tab-content">
                <div class="panel" style="text-align: center; height: 280px; display: flex; flex-direction: column; justify-content: center; align-items: center;">
                    <button class="action-btn" onclick="launchGnMath()" style="width:220px; border-color:var(--boost); color:var(--boost); background:none; font-weight:bold;">OPEN GN-MATH</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let audioCtx, source, gainNode, filterNode, isDev = false, isVision = false, isClear = false;
    const ui = { f: document.getElementById('f'), vid: document.getElementById('vid'), vol: document.getElementById('volBoost'), volVal: document.getElementById('volVal') };

    function showTab(t, btn) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.nav-tabs button').forEach(el => el.classList.remove('active'));
        document.getElementById('tab'+t.charAt(0).toUpperCase()+t.slice(1)).classList.add('active');
        btn.classList.add('active');
    }

    function initAudio() {
        if (!audioCtx && ui.vid.src) {
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            source = audioCtx.createMediaElementSource(ui.vid);
            gainNode = audioCtx.createGain();
            filterNode = audioCtx.createBiquadFilter();
            filterNode.type = "highpass";
            filterNode.frequency.value = 150; 
            source.connect(gainNode);
            gainNode.connect(audioCtx.destination);
        }
    }

    function toggleClearerAudio() {
        isClear = !isClear;
        initAudio();
        if (isClear) {
            gainNode.disconnect();
            gainNode.connect(filterNode);
            filterNode.connect(audioCtx.destination);
            document.getElementById('clearBtn').innerText = "AUDIO: CLEAR";
        } else {
            filterNode.disconnect();
            gainNode.connect(audioCtx.destination);
            document.getElementById('clearBtn').innerText = "AUDIO: OFF";
        }
    }

    function toggleVision() {
        isVision = !isVision;
        ui.vid.style.filter = isVision ? "brightness(1.8) contrast(1.2) saturate(1.1)" : "none";
        document.getElementById('visionBtn').innerText = isVision ? "ULTRABRIGHT: ON" : "ULTRABRIGHT: OFF";
    }

    function applyCloak(title, domain) {
        document.title = title;
        document.getElementById('dynamic-favicon').href = `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;
    }

    function applyCustomCloak() {
        const t = document.getElementById('cloakTitle').value;
        const d = document.getElementById('cloakDomain').value;
        if(t && d) applyCloak(t, d);
    }

    function resetCloak() {
        document.title = "max-stash";
        const canvas = document.createElement('canvas');
        canvas.width = 64; canvas.height = 64;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#007bff'; ctx.beginPath(); ctx.arc(32, 32, 32, 0, Math.PI * 2); ctx.fill();
        ctx.fillStyle = '#ffffff'; ctx.beginPath(); ctx.arc(16, 32, 16, 0, Math.PI * 2); ctx.fill();
        ctx.beginPath(); ctx.arc(48, 32, 16, 0, Math.PI * 2); ctx.fill();
        document.getElementById('dynamic-favicon').href = canvas.toDataURL('image/png');
    }

    function launchGnMath() {
        fetch("https://cdn.jsdelivr.net/gh/gn-math/gn-math-DONTDMCA@main/autoupdate.html?t=" + Date.now())
        .then(r => r.text()).then(t => {
            const w = window.open("about:blank", "_blank");
            if (w) { w.document.open(); w.document.write(t); w.document.close(); }
        });
    }

    function systemWipe() {
        if (ui.vid.src) { URL.revokeObjectURL(ui.vid.src); ui.vid.src = ""; ui.vid.style.display = "none"; }
        isDev = false; isVision = false; isClear = false;
        ui.vol.max = "15"; ui.vol.value = "10"; ui.volVal.innerText = "100%";
        ui.vid.style.filter = "none";
        resetCloak();
        showTab('readme', document.getElementById('tabBtnReadme'));
    }

    setInterval(() => {
        if (window.performance && window.performance.memory) {
            document.getElementById('usedRam').innerText = (window.performance.memory.usedJSHeapSize / 1048576).toFixed(2) + " MB";
        }
    }, 1000);

    function devUnlock() {
        if (prompt("Key:") === "123!@#qweQWE") {
            isDev = true; ui.vol.max = "50"; 
            ui.volVal.style.color = "var(--boost)";
        }
    }

    ui.vol.oninput = () => {
        initAudio();
        if (gainNode) gainNode.gain.value = ui.vol.value / 10;
        ui.volVal.innerText = (ui.vol.value * 10) + "%";
    };

    document.getElementById('mainBtn').onclick = () => {
        const file = ui.f.files[0];
        if (file) { ui.vid.src = URL.createObjectURL(file); ui.vid.style.display = "block"; }
    };

    window.onload = () => { setTimeout(resetCloak, 1000); };
</script>
</body>
</html>
